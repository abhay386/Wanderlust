 <% layout('layouts/boilerplate') %>

 <div class="row mt-3">
    <h1 class="col-6 offset-2">login on wanderlust</h1>
    <div class="col-8 offset-2" >
          <form action="/login" method="POST" class="needs-validation" novalidate>
              <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input name="username" class="form-control" type="text" placeholder="Enter your username" required id="username">
            <div class="valid-feedback"> looks good!</div>
          </div>
          <!-- email -->
           <!-- <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input name="email" class="form-control" type="text" placeholder="Enter your Email" required id="email">
          </div> -->
          <!-- password -->
             <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input name="password" class="form-control" type="password" placeholder="Enter your Password" required id="password">
          </div>
          <button type="submit" class="btn btn-success">login</button>
       </form>
    </div>
</div>